# ── SERVIDOR ──────────────────────────────────────────
PORT=3000

# ── BASE DE DATOS ──────────────────────────────────────
# Ruta al archivo SQLite (relativa a /backend)
DATABASE_URL=./datos/estacion_del_sol.db

# ── CORREO (Gmail con contraseña de aplicación) ────────
EMAIL_USER=Andres.pachay@gmail.com
# Contraseña de aplicación de Google (16 caracteres, sin espacios)
# Generarla en: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── SEGURIDAD PANEL ADMIN ──────────────────────────────
# Cambiar por una cadena larga y aleatoria
ADMIN_API_KEY=cambia_esto_por_una_clave_segura_2026

# ── PAYPHONE ───────────────────────────────────────────
# Obtener en: https://developer.payphone.app → tu aplicación tipo "API"
PAYPHONE_TOKEN=tu_bearer_token_de_payphone
PAYPHONE_STORE_ID=tu_store_id_de_payphone

# ── WHATSAPP (CallMeBot — gratis, sin cuenta Twilio) ───
# 1. Envía "I allow callmebot to send me messages" al +34 644 47 93 97 en WhatsApp
# 2. Recibirás tu API key
CALLMEBOT_API_KEY=tu_api_key_de_callmebot
HOTEL_WHATSAPP=593963750763

# ── FRONTEND ───────────────────────────────────────────
# En desarrollo: http://localhost:5500
# En producción: https://estaciondelsol.ec
FRONTEND_URL=https://hotelestaciondelsol.com

# ── NODE ENV ───────────────────────────────────────────
NODE_ENV=development
